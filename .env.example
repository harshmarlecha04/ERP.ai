# ─────────────────────────────────────────────────────────────────────────
# Frontend environment variables (Vite)
# Copy this file to `.env` and fill in real values.
# Anything prefixed VITE_ is embedded in the client bundle (safe for anon keys,
# NOT for secrets).
# ─────────────────────────────────────────────────────────────────────────

# Your Supabase project URL, e.g. https://abcdxyz.supabase.co
VITE_SUPABASE_URL=

# Your Supabase publishable / anon key (safe to expose to the browser)
VITE_SUPABASE_PUBLISHABLE_KEY=

# (Optional) Supabase project ref/id, if any code references it
VITE_SUPABASE_PROJECT_ID=


# ─────────────────────────────────────────────────────────────────────────
# Edge Function secrets — DO NOT put these in the frontend .env above.
# Set them with the Supabase CLI instead:
#
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
# Reference (already provided automatically by Supabase to functions):
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#
# You must set manually:
#   ANTHROPIC_API_KEY        -> from https://console.anthropic.com (AI features)
#   (email provider key)     -> only if you migrate auth-email-hook (see guide)
# ─────────────────────────────────────────────────────────────────────────
